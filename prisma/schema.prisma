generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  productos producto[]
}

model cliente {
  id            Int            @id @default(autoincrement())
  nombreNegocio String
  nombreDueno   String?
  telefono      String?
  direccion     String?
  zona          String?
  email         String?
  cuit          String         @unique
  activo        Boolean        @default(true)
  notaCreditos  nota_credito[]
  ventas        venta[]
}

model producto {
  id             Int            @id @default(autoincrement())
  nombre         String
  categoriaId    Int?
  stock          Int            @default(0)
  costoUnitario  Decimal        @db.Decimal(10, 2)
  precioUnitario Decimal        @db.Decimal(10, 2)
  creadoEn       DateTime       @default(now())
  activo         Boolean        @default(true)
  detalles       detalleventa[]
  categoria      categoria?     @relation(fields: [categoriaId], references: [id])

  @@index([categoriaId], map: "producto_categoriaId_fkey")
}

model venta {
  id           Int            @id @default(autoincrement())
  fecha        DateTime       @default(now())
  clienteId    Int?
  usuarioId    Int
  total        Decimal        @db.Decimal(10, 2)
  estado       EstadoVenta    @default(ACTIVA)
  notasCredito nota_credito[]
  detalles     detalleventa[]
  cliente      cliente?       @relation(fields: [clienteId], references: [id])
  usuario      usuario        @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([clienteId])
}

model detalleventa {
  id                  Int                    @id @default(autoincrement())
  ventaId             Int
  productoId          Int
  cantidad            Int
  precioUnitario      Decimal                @db.Decimal(10, 2)
  cantidadAcreditada  Int                    @default(0)
  producto            producto               @relation(fields: [productoId], references: [id])
  venta               venta                  @relation(fields: [ventaId], references: [id])
  notasCreditoDetalle nota_credito_detalle[]

  @@index([ventaId])
  @@index([productoId])
}

model tipo_usuario {
  id          Int       @id @default(autoincrement())
  descripcion String?
  usuarios    usuario[]
}

model usuario {
  id            Int            @id @default(autoincrement())
  dni           String         @unique
  nombre        String
  apellido      String
  telefono      String?
  direccion     String?
  zona          String?
  email         String?        @unique
  password      String
  creadoEn      DateTime       @default(now())
  tipoUsuarioId Int?           @default(1)
  notaCreditos  nota_credito[]
  tipoUsuario   tipo_usuario?  @relation(fields: [tipoUsuarioId], references: [id])
  ventas        venta[]

  @@index([tipoUsuarioId], map: "usuario_tipoUsuarioId_fkey")
}

model nota_credito {
  id         Int                    @id @default(autoincrement())
  fecha      DateTime               @default(now())
  total      Decimal                @db.Decimal(10, 2)
  usuarioId  Int
  estado     nota_credito_estado    @default(DISPONIBLE)
  montoUsado Decimal                @default(0.00) @db.Decimal(10, 2)
  clienteId  Int
  ventaId    Int?
  cliente    cliente                @relation(fields: [clienteId], references: [id])
  usuario    usuario                @relation(fields: [usuarioId], references: [id])
  detalles   nota_credito_detalle[]
  venta venta? @relation(fields: [ventaId], references: [id])

  @@index([usuarioId])
  @@index([clienteId])
  @@index([ventaId])
}

model nota_credito_detalle {
  id             Int          @id @default(autoincrement())
  notaCreditoId  Int
  cantidad       Int
  precioUnitario Decimal      @db.Decimal(10, 2)
  ventaDetalleId Int
  notaCredito    nota_credito @relation(fields: [notaCreditoId], references: [id])
  ventaDetalle   detalleventa @relation(fields: [ventaDetalleId], references: [id])

  @@index([notaCreditoId])
  @@index([ventaDetalleId])
}

enum EstadoVenta {
  ACTIVA
  ANULADA
  ACREDITADA
  PARCIALMENTE_ACREDITADA
}

enum nota_credito_estado {
  DISPONIBLE
  PARCIAL
  USADA
  ANULADA
}
